## User settings
xcuserdata/
*.xcuserstate

## Build artifacts
build/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

## Swift Package Manager
.swiftpm/
.build/
# Package.resolved is kept in git so SPM pins are reproducible.

## CocoaPods (if used later)
Pods/
# Don't blanket-ignore .xcworkspace — Xcode requires
# .xcodeproj/project.xcworkspace/contents.xcworkspacedata to wire SPM
# products into targets. Ignore only top-level / Pods workspaces.
/*.xcworkspace

## fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

## macOS
.DS_Store

## Secrets
# Secrets.swift defaults to reading env vars — safe to commit. If you switch
# to hardcoded keys for local dev, uncomment the next line.
# Secrets.swift
GoogleService-Info.plist
