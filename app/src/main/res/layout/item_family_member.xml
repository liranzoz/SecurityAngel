<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieMemberAvatar"
        android:layout_width="50dp"
        android:layout_height="50dp"
        app:lottie_rawRes="@raw/anim_male_avater"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        android:scaleType="centerCrop"
        android:scaleX="1.2"
        android:scaleY="1.2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:id="@+id/tvMemberName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Name"
        android:textStyle="bold"
        android:textColor="#212121"
        android:textSize="16sp"
        app:layout_constraintStart_toEndOf="@id/lottieMemberAvatar"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvMemberStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Safe"
        android:textSize="12sp"
        android:textColor="#065F46"
        android:backgroundTint="#D1FAE5"
        android:background="@drawable/bg_status_pill"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        app:layout_constraintStart_toEndOf="@id/lottieMemberAvatar"
        app:layout_constraintTop_toBottomOf="@id/tvMemberName" />

</androidx.constraintlayout.widget.ConstraintLayout>